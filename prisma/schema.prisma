generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int              @id @default(autoincrement())
  email      String           @unique
  name       String?
  password   String
  createdAt  DateTime         @default(now())
  converters SavedConverter[]
}

model SavedConverter {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  name      String
  data      String
  createdAt DateTime @default(now())
}
